---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Hero from "../../components/nosotros/Hero";
import Intro from "../../components/nosotros/Intro";
import Audience from "../../components/nosotros/Audience";
import Courses from "../../components/nosotros/Courses";
import Certification from "../../components/nosotros/Certification";
import Benefits from "../../components/nosotros/Benefits";
import Methodology from "../../components/nosotros/Methodology";
import Testimonials from "../../components/nosotros/Testimonials";
import FinalCta from "../../components/nosotros/FinalCta";
import { estrategiaSeo } from "../../config/seoConfig";
---

<Layout seo={estrategiaSeo}>
  <Header active="estrategia" ctaLabel="Contáctanos" />
  <main>
    <Hero client:load />
    <Intro client:visible />
    <Audience client:visible />
    <Courses client:visible />
    <Certification client:visible />
    <Benefits client:visible />
    <Methodology client:visible />
    <Testimonials client:visible />
    <FinalCta client:visible />
  </main>
  <Footer />
</Layout>
