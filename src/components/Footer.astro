---
import { siteConfig } from "../config/site.config";
import brandLogo from "../assets/logo.png?url";

interface Props {
  /** Texto opcional bajo el logo (p. ej. página Nosotros). */
  overlapLead?: string;
}

const { overlapLead } = Astro.props;

const socialWrapClass =
  "flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-white text-footer transition hover:bg-white/95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-footer";
const iconClass = "h-5 w-5 fill-current";
---

<section class="relative" aria-label="Pie de página">
  <!-- Franja crema superior: el borde inferior es la “junta” con el azul -->
  <div class="bg-[#FDEFE7] pt-6 pb-16 md:pt-8 md:pb-20" aria-hidden="true">
  </div>

  <footer id="contacto" class="relative z-10 bg-footer text-white">
    <!-- Logo: absolute, centrado en la junta crema/azul; alineado a la izquierda -->
    <div
      class="pointer-events-none absolute inset-x-0 top-0 z-30 -translate-y-1/2"
    >
      <div class="container flex justify-start">
        <div class="pointer-events-auto w-auto max-w-[min(100%,320px)]">
          <div
            class="rounded-2xl bg-white px-4 py-3 shadow-card sm:px-6 sm:py-4 md:rounded-[1.25rem] md:px-5 md:py-4"
          >
            <a
              href="/"
              class="inline-flex outline-none ring-primary focus-visible:rounded-lg focus-visible:ring-2 focus-visible:ring-offset-2"
            >
              <img
                src={brandLogo}
                alt={siteConfig.name}
                width="320"
                height="80"
                class="h-11 w-auto sm:h-12"
                loading="lazy"
                decoding="async"
              />
            </a>
            {
              overlapLead ? (
                <p class="mt-3 max-w-md text-sm leading-relaxed text-primary/85">
                  {overlapLead}
                </p>
              ) : null
            }
          </div>
        </div>
      </div>
    </div>

    <!-- Hueco para el logo que “cuelga” del borde superior -->
    <div
      class="container px-5 pb-10 pt-[5.25rem] sm:px-6 md:pb-14 md:pt-[5.75rem] lg:px-12 lg:pb-16 lg:pt-24"
    >
      <div
        class="grid grid-cols-1 gap-12 sm:gap-14 md:grid-cols-3 md:gap-x-10 md:gap-y-0 lg:gap-x-14 xl:gap-x-20"
      >
        <div class="min-w-0">
          <div class="mb-4 text-base font-extrabold tracking-tight md:text-lg">
            Explora
          </div>
          <ul class="space-y-2.5 text-sm leading-relaxed text-white/95">
            <li><a href="/" class="transition hover:text-white">Inicio</a></li>
            <li>
              <a href="/estrategia" class="transition hover:text-white"
                >Estrategia</a
              >
            </li>
            <li>
              <a href="/nosotros" class="transition hover:text-white"
                >Quiénes somos</a
              >
            </li>
          </ul>
        </div>

        <div class="min-w-0">
          <div class="mb-4 text-base font-extrabold tracking-tight md:text-lg">
            Contacto
          </div>
          <ul class="space-y-2.5 text-sm leading-relaxed text-white/95">
            <li>
              <a
                href={`mailto:${siteConfig.contact.email}`}
                class="break-all transition hover:text-white"
              >
                {siteConfig.contact.email}
              </a>
            </li>
            <li>
              <a
                href={`tel:${siteConfig.contact.phoneE164}`}
                class="transition hover:text-white"
              >
                {siteConfig.contact.phone}
              </a>
            </li>
          </ul>
        </div>

        <div class="min-w-0">
          <div class="mb-4 text-base font-extrabold tracking-tight md:text-lg">
            Síguenos en nuestras redes
          </div>
          <div class="flex flex-wrap gap-3">
            <a
              href={siteConfig.social.linkedin}
              class={socialWrapClass}
              aria-label="LinkedIn"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class={iconClass} viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
            </a>
            <a
              href={siteConfig.social.facebook}
              class={socialWrapClass}
              aria-label="Facebook"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class={iconClass} viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M9.101 23.691v-9.8H7.169v-3.9h1.932V8.156c0-1.62.457-2.964 1.372-4.037.934-1.073 2.192-1.608 3.771-1.608h2.85v3.9h-1.822c-.978 0-1.588.454-1.82 1.364v2.996h3.43l-.409 3.9h-3.02v9.801H9.1z"
                ></path>
              </svg>
            </a>
            <a
              href={siteConfig.social.instagram}
              class={socialWrapClass}
              aria-label="Instagram"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class={iconClass} viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8 1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5 5 5 0 0 1-5 5 5 5 0 0 1-5-5 5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3z"
                ></path>
              </svg>
            </a>
            <a
              href={siteConfig.social.youtube}
              class={socialWrapClass}
              aria-label="YouTube"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class={iconClass} viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                ></path>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <p
        class="mt-14 border-t border-white/20 pt-8 text-center text-xs leading-relaxed text-white/75 md:mt-16 md:pt-9"
      >
        © {new Date().getFullYear()}
        {siteConfig.name}. Todos los derechos reservados.
      </p>
    </div>
  </footer>
</section>
