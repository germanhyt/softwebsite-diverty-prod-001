---
import { siteConfig } from "../config/site.config";

interface Props {
  /** Tarjeta blanca con logo encima del footer (prototipo nosotros). */
  overlapLogo?: boolean;
  /** Texto destacado bajo el logo en variante overlap. */
  overlapLead?: string;
  /** Texto breve bajo el nombre de marca (columna 1). */
  mission?: string;
}

const {
  overlapLogo = false,
  overlapLead = "Agenda una sesión de evaluación sin compromiso y conoce nuestro enfoque personalizado.",
  mission = "Neurodesarrollo, Montessori y capacitación profesional para familias y especialistas en Perú.",
} = Astro.props;

const iconClass = "h-6 w-6 fill-current";
---

{
  overlapLogo && (
    <div class="relative z-10 bg-surface-cream pb-12 pt-4 md:pb-16">
      <div class="container">
        <div class="mx-auto max-w-lg -mb-16 rounded-2xl bg-white px-8 py-6 text-center shadow-card md:-mb-20">
          <div class="text-2xl font-extrabold text-primary">{siteConfig.name}</div>
          <p class="mt-3 text-sm leading-relaxed text-primary/85">{overlapLead}</p>
        </div>
      </div>
    </div>
  )
}

<footer id="contacto" class:list={["bg-footer text-white", overlapLogo && "pt-20 md:pt-24"]}>
  <div class="container py-12 md:py-16">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4 lg:gap-8">
      <div class="lg:col-span-1">
        <div class="mb-3 text-2xl font-extrabold tracking-tight">{siteConfig.name}</div>
        <p class="max-w-xs text-sm leading-relaxed text-white/85">{mission}</p>
      </div>

      <div>
        <div class="mb-3 text-lg font-extrabold">Explora</div>
        <ul class="space-y-2 text-sm text-white/90">
          <li><a href="/" class="hover:text-accent-orange">Inicio</a></li>
          <li><a href="/estrategia" class="hover:text-accent-orange">Estrategia</a></li>
          <li><a href="/nosotros" class="hover:text-accent-orange">Quiénes somos</a></li>
        </ul>
      </div>

      <div>
        <div class="mb-3 text-lg font-extrabold">Contacto</div>
        <ul class="space-y-2 text-sm text-white/90">
          <li>
            <a href={`mailto:${siteConfig.contact.email}`} class="break-all hover:text-accent-orange">
              {siteConfig.contact.email}
            </a>
          </li>
          <li>
            <a href={`tel:${siteConfig.contact.phone.replace(/\s/g, "")}`} class="hover:text-accent-orange">
              {siteConfig.contact.phone}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <div class="mb-3 text-lg font-extrabold">Síguenos</div>
        <div class="flex flex-wrap gap-4 text-white/90">
          <a href={siteConfig.social.linkedin} class="hover:text-accent-orange" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
            <svg class={iconClass} viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href={siteConfig.social.facebook} class="hover:text-accent-orange" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
            <svg class={iconClass} viewBox="0 0 24 24" aria-hidden="true"><path d="M9.101 23.691v-9.8H7.169v-3.9h1.932V8.156c0-1.62.457-2.964 1.372-4.037.934-1.073 2.192-1.608 3.771-1.608h2.85v3.9h-1.822c-.978 0-1.588.454-1.82 1.364v2.996h3.43l-.409 3.9h-3.02v9.801H9.1z"/></svg>
          </a>
          <a href={siteConfig.social.instagram} class="hover:text-accent-orange" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
            <svg class={iconClass} viewBox="0 0 24 24" aria-hidden="true"><path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8 1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5 5 5 0 0 1-5 5 5 5 0 0 1-5-5 5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3z"/></svg>
          </a>
          <a href={siteConfig.social.youtube} class="hover:text-accent-orange" aria-label="YouTube" target="_blank" rel="noopener noreferrer">
            <svg class={iconClass} viewBox="0 0 24 24" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href={siteConfig.contact.whatsapp} class="hover:text-accent-orange" aria-label="WhatsApp" target="_blank" rel="noopener noreferrer">
            <svg class={iconClass} viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <p class="mt-12 border-t border-white/15 pt-8 text-center text-xs text-white/70">
      © {new Date().getFullYear()}
      {siteConfig.name}. Todos los derechos reservados.
    </p>
  </div>
</footer>
