---
import { benefits } from "../../data/nosotrosTraining";
---

<section
  class="bg-surface-cream py-16 md:py-20"
  aria-labelledby="benefits-title"
>
  <div class="container">
    <h2
      id="benefits-title"
      class="mb-12 text-center text-3xl text-primary sm:mb-14 sm:text-4xl"
    >
      Beneficios de capacitarte con nosotros
    </h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-8">
      {
        benefits.map((b) => (
          <article class="overflow-hidden rounded-2xl text-center shadow-card ring-1 bg-white ring-primary/10">
            <div class="relative aspect-[4/3] w-full overflow-hidden">
              <img
                src={b.image.src}
                alt={b.image.alt}
                class="h-full w-full object-cover object-center"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-8">
              <h3 class="mb-3 text-xl font-bold text-primary">{b.title}</h3>
              <p class="text-base leading-relaxed text-primary/85">{b.text}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
