---
import { essence } from "../../data/nosotrosPage";
---

<section class="bg-surface-cream py-16 md:py-24" aria-labelledby="essence-title">
  <div class="container">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="rounded-3xl bg-surface-card p-8 shadow-card lg:bg-transparent lg:p-0 lg:shadow-none">
        <h2 id="essence-title" class="mb-6 text-3xl text-primary sm:text-4xl">
          {essence.title}
        </h2>
        <p class="text-lg leading-relaxed text-primary/90">{essence.body}</p>
      </div>
      <div class="overflow-hidden rounded-3xl shadow-card ring-1 ring-primary/10">
        <img
          src={essence.image.src}
          alt={essence.image.alt}
          width={1000}
          height={720}
          class="aspect-[4/3] w-full object-cover lg:aspect-auto lg:min-h-[320px]"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
