---
import { siteConfig } from "../../config/site.config";
import { trainingHero } from "../../data/nosotrosTraining";
---

<section
  id="inicio"
  class="bg-primary pt-28 text-white  md:pt-36"
  aria-labelledby="hero-title"
>
  <div class="container">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-12 xl:gap-16">
      <div class="relative flex justify-center lg:justify-start order-2 lg:order-1">
        <img
          src={trainingHero.image.src}
          alt={trainingHero.image.alt}
          width={1200}
          height={1000}
          class="relative z-[1] w-full max-w-xl object-contain drop-shadow-lg lg:max-w-none"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
      <div class="max-w-xl lg:max-w-none order-1 lg:order-2">
        <h1
          id="hero-title"
          class="mb-6 text-3xl font-bold leading-tight sm:text-3xl lg:text-4xl"
        >
          {siteConfig.tagline}
        </h1>
        <p class="max-w-xl text-base leading-relaxed text-white/90 sm:text-lg">
          Únete a profesionales que ya aplican lo aprendido en Diverty: sesiones en vivo,
          práctica guiada y certificación con respaldo.
        </p>
      </div>
    </div>
  </div>
</section>
