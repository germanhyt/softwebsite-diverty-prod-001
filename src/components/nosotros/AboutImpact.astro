---
import { impact } from "../../data/nosotrosPage";
---

<section class="border-t border-primary/10 bg-surface-cream py-16 md:py-24" aria-labelledby="impact-title">
  <div class="container">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="order-2 overflow-hidden rounded-3xl shadow-card ring-1 ring-primary/10 lg:order-1">
        <img
          src={impact.image.src}
          alt={impact.image.alt}
          width={1000}
          height={720}
          class="aspect-[4/3] w-full object-cover lg:aspect-auto lg:min-h-[320px]"
          loading="lazy"
        />
      </div>
      <div class="order-1 rounded-3xl bg-surface-card p-8 shadow-card lg:order-2 lg:bg-transparent lg:p-0 lg:shadow-none">
        <h2 id="impact-title" class="mb-6 text-3xl text-primary sm:text-4xl">
          {impact.title}
        </h2>
        <p class="text-lg leading-relaxed text-primary/90">{impact.body}</p>
      </div>
    </div>
  </div>
</section>
