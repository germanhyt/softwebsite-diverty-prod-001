---
import { certification } from "../../data/nosotrosTraining";
---

<section class="bg-[#FDEFE7] py-16 md:py-24" aria-labelledby="cert-title">
  <div class="container max-w-5xl md:max-w-[96rem]">
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:items-stretch">
      <!-- Image Container (mismo maquetado que Atención a domicilio) -->
      <div class="sm:flex hidden relative z-10 w-full sm:w-[45%] lg:w-[40%]">
        <img
          src={certification.badge.src}
          alt={certification.badge.alt}
          width={800}
          height={600}
          class="aspect-[4/3] w-full rounded-[1.5rem] object-cover shadow-xl sm:aspect-auto sm:h-full lg:rounded-[3.5rem]"
          loading="lazy"
          decoding="async"
        />
      </div>

      <!-- Green Pill Container -->
      <div
        class="relative my-6 flex w-full flex-col gap-6 justify-center rounded-[1.5rem] bg-[#2E8B57] py-4 px-8 text-white shadow-lg sm:-ml-12 sm:flex-1 sm:rounded-l-none sm:rounded-r-[3.5rem] sm:pl-20 sm:pr-16 lg:pl-24"
      >
        <div class="flex sm:hidden relative z-10 w-full sm:w-[45%] lg:w-[40%]">
          <img
            src={certification.badge.src}
            alt={certification.badge.alt}
            width={800}
            height={600}
            class="aspect-[4/3] w-full rounded-[1.5rem] object-cover shadow-xl sm:aspect-auto sm:h-full lg:rounded-[3.5rem]"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div>
          <h2
            id="cert-title"
            class="mb-3 text-2xl font-bold leading-tight sm:text-xl lg:text-2xl"
          >
            {certification.title}
          </h2>
          <p class="max-w-md text-base leading-relaxed text-white/95 lg:text-lg">
            {certification.body}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
