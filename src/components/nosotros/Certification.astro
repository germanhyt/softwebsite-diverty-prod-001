---
import { certification } from "../../data/nosotrosTraining";
---

<section class="bg-surface-cream py-12 md:py-16" aria-labelledby="cert-title">
  <div class="container max-w-5xl">
    <div class="flex flex-col gap-6 rounded-3xl bg-accent-green p-6 text-white shadow-card sm:flex-row sm:items-center sm:gap-8 sm:p-8 md:p-10">
      <img
        src={certification.badge.src}
        alt={certification.badge.alt}
        width={200}
        height={200}
        class="mx-auto h-32 w-32 shrink-0 rounded-full border-4 border-white/40 object-cover sm:mx-0 sm:h-36 sm:w-36"
        loading="lazy"
      />
      <div>
        <h2 id="cert-title" class="mb-3 text-2xl sm:text-3xl">
          {certification.title}
        </h2>
        <p class="text-base leading-relaxed text-white/95 sm:text-lg">{certification.body}</p>
      </div>
    </div>
  </div>
</section>
