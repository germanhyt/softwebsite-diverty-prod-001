---
import { methodology } from "../../data/nosotrosTraining";
---

<section class="container" aria-labelledby="method-title">
  <div class="bg-[#FFE1CF] py-16 md:py-24 rounded-[1.75rem]">
    <h2
      id="method-title"
      class="text-center text-3xl font-bold text-primary sm:text-4xl mb-6"
    >
      {methodology.title}
    </h2>
    <p class="mb-12 text-center text-base text-primary/90">
      Nuestros programas se desarrollan en modalidad semipresencial, combinando
      teoría aplicada con experiencias prácticas.
    </p>

    <div
      class="grid gap-10 md:grid-cols-2 md:gap-12 max-w-64 md:max-w-2xl lg:max-w-4xl 3xl:max-w-5xl mx-auto"
    >
      {
        methodology.columns.map((col) => (
          <div class="flex flex-col overflow-hidden rounded-[1.35rem] shadow-card ring-1 ring-primary/10">
            <div class="aspect-[16/11] w-full overflow-hidden bg-primary/5">
              <img
                src={col.image.src}
                alt={col.image.alt}
                width={800}
                height={550}
                class="h-full w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="min-h-[15rem] lg:min-h-[12rem]  rounded-b-[1.35rem] bg-accent-orange px-6 py-5 text-white sm:px-8 sm:py-6">
              <h3 class="text-lg font-bold sm:text-xl">{col.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-white/95 sm:text-base">
                {col.body}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
