---
import { ourStory, brandPillars } from "../../data/familiesHome";
---

<section class="bg-surface-peach py-16 md:py-24" aria-labelledby="story-title">
  <div class="container">
    <div class="grid gap-10 lg:grid-cols-2 lg:gap-14">
      <div>
        <h2 id="story-title" class="mb-6 text-3xl text-primary sm:text-4xl">
          {ourStory.title}
        </h2>
        <p class="text-lg leading-relaxed text-primary/90">{ourStory.body}</p>
      </div>
      <div class="flex flex-col gap-4">
        {
          brandPillars.map((p) => (
            <div class="rounded-2xl bg-accent-orange p-6 text-white shadow-card sm:p-8">
              <h3 class="mb-2 text-xl">{p.name}</h3>
              <p class="leading-relaxed text-white/95">{p.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
