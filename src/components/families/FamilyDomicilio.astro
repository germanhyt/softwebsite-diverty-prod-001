---
import { domicilio } from "../../data/familiesHome";
---

<section class="bg-surface-cream py-12 md:py-16" aria-labelledby="domicilio-title">
  <div class="container max-w-5xl">
    <div class="flex flex-col gap-6 rounded-3xl bg-accent-green p-6 text-white shadow-card sm:flex-row sm:items-center sm:gap-8 sm:p-8 md:p-10">
      <img
        src={domicilio.image.src}
        alt={domicilio.image.alt}
        width={280}
        height={280}
        class="mx-auto h-36 w-36 shrink-0 rounded-full border-4 border-white/35 object-cover sm:mx-0 sm:h-40 sm:w-40"
        loading="lazy"
      />
      <div>
        <h2 id="domicilio-title" class="mb-3 text-2xl sm:text-3xl">
          {domicilio.title}
        </h2>
        <p class="text-base leading-relaxed text-white/95 sm:text-lg">{domicilio.body}</p>
      </div>
    </div>
  </div>
</section>
