---
import { familyNeuro } from "../../data/familiesHome";
---

<section class="bg-surface-cream py-16 md:py-24" aria-labelledby="neuro-title">
  <div class="container">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div>
        <h2 id="neuro-title" class="mb-6 text-3xl text-primary sm:text-4xl">
          {familyNeuro.title}
        </h2>
        <p class="mb-8 text-lg leading-relaxed text-primary/90">{familyNeuro.body}</p>
        <a
          href="/#contacto"
          class="inline-flex rounded-full bg-primary px-8 py-3 text-base font-bold text-white shadow-md transition hover:bg-primary-dark"
        >
          Agenda una sesión →
        </a>
      </div>
      <img
        src={familyNeuro.illustration.src}
        alt={familyNeuro.illustration.alt}
        width={900}
        height={700}
        class="w-full rounded-2xl object-cover shadow-card"
        loading="lazy"
      />
    </div>
  </div>
</section>
