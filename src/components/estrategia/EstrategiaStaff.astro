---
import { estrategiaStaff, estrategiaStaffCta } from "../../data/estrategiaPage";
---

<section
  class="bg-surface-cream pb-16 pt-4 md:pb-24 md:pt-6"
  aria-labelledby="estrategia-staff-title"
>
  <div class="container">
    <h2
      id="estrategia-staff-title"
      class="text-center text-2xl font-bold tracking-tight text-neutral-900 sm:text-3xl"
    >
      Nuestro staff
    </h2>

    <ul
      class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-10 sm:grid-cols-2 sm:gap-x-8 sm:gap-y-12 lg:grid-cols-3"
    >
      {
        estrategiaStaff.map((member) => (
          <li class="flex flex-col items-center text-center">
            <div class="w-full max-w-[280px] overflow-hidden rounded-[1.15rem] shadow-card ring-1 ring-black/[0.06] sm:max-w-none">
              <img
                src={member.photo.src}
                alt={member.photo.alt}
                width={400}
                height={480}
                class="aspect-[4/5] w-full object-cover object-top"
                loading="lazy"
                decoding="async"
              />
            </div>
            <p class="mt-5 text-lg font-bold text-neutral-900">{member.name}</p>
            <p class="mt-1 text-sm font-medium text-neutral-500">{member.role}</p>
          </li>
        ))
      }
    </ul>

    <div class="mt-14 flex justify-center md:mt-16">
      <a
        href={estrategiaStaffCta.href}
        class="inline-flex items-center gap-2 rounded-full bg-footer px-8 py-3.5 text-sm font-bold text-white shadow-md transition hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-footer focus-visible:ring-offset-2 sm:text-base"
      >
        {estrategiaStaffCta.label}
        <svg
          class="h-4 w-4 shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
