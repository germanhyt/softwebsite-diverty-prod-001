---
import type { EstrategiaSplitBlock } from "../../data/estrategiaPage";

interface Props {
  block: EstrategiaSplitBlock;
}

const { block } = Astro.props;
const { title, paragraphs, signature, image, imageLeft } = block;
---

<section
  class="scroll-mt-28 bg-surface-cream py-14 md:py-20"
  aria-labelledby={`estrategia-${block.id}-title`}
>
  <div class="container">
    <div
      class:list={[
        "grid items-center gap-10 lg:gap-14 xl:gap-16",
        "lg:grid-cols-2",
        imageLeft && "lg:[&>div:first-child]:order-2 lg:[&>div:last-child]:order-1",
      ]}
    >
      <div class="min-w-0">
        <h2
          id={`estrategia-${block.id}-title`}
          class="text-2xl font-bold tracking-tight text-neutral-900 sm:text-3xl"
        >
          {title}
        </h2>
        <div class="mt-5 space-y-4 text-base leading-relaxed text-neutral-700 sm:text-[1.05rem]">
          {paragraphs.map((p) => <p>{p}</p>)}
          {
            signature ? (
              <p class="pt-1 text-neutral-900">
                <span class="font-bold">{signature}</span>
              </p>
            ) : null
          }
        </div>
      </div>
      <div class="min-w-0">
        <div
          class="overflow-hidden rounded-[1.25rem] shadow-card ring-1 ring-black/[0.06]"
        >
          <img
            src={image.src}
            alt={image.alt}
            width={900}
            height={600}
            class="h-auto w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>
</section>
