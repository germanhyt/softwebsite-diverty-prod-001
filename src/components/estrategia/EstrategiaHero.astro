---
import { estrategiaHero } from "../../data/estrategiaPage";
---

<section
  class="bg-hero-green text-white"
  aria-labelledby="estrategia-hero-title"
>
  <div class="container pt-28 md:pt-36">
    <div class="grid items-center gap-2 lg:grid-cols-3 lg:gap-12 xl:gap-16">
      <div class="sm:col-span-2 order-2 lg:order-1">
        <div class="overflow-hidden rounded-[1.25rem]">
          <img
            src={estrategiaHero.image.src}
            alt={estrategiaHero.image.alt}
            class="h-auto w-full object-cover"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <h1
          id="estrategia-hero-title"
          class="text-3xl font-bold leading-tight sm:text-4xl lg:text-[2.65rem] lg:leading-[1.12]"
        >
          {estrategiaHero.title}
        </h1>
        <p
          class="mt-5 max-w-xl text-base leading-relaxed text-white/95 sm:text-lg"
        >
          {estrategiaHero.body}
        </p>
      </div>
    </div>
  </div>
</section>
