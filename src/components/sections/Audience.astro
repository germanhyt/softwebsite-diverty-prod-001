---
import { audience } from "../../data/nosotrosTraining";

const fullBleed =
  "usePhotoBackground" in audience && audience.usePhotoBackground === true;
---

<section
  id="publico"
  class="scroll-mt-28 bg-surface-cream py-10 md:py-14"
  aria-labelledby="audience-title"
>
  {
    fullBleed ? (
      <div class="container">
        <div class="rounded-[1.35rem] sm:rounded-[1.75rem]">
          <div class="relative md:min-h-[26rem] md:overflow-hidden md:rounded-[1.75rem] lg:min-h-[28rem]">
            <!-- Móvil: imagen arriba; desktop: foto a pantalla completa detrás -->
            <div class="relative h-52 w-full shrink-0 overflow-hidden rounded-t-2xl sm:h-56 md:absolute md:inset-0 md:h-full md:min-h-[26rem] md:rounded-2xl lg:min-h-[28rem]">
              <img
                src={audience.photo.src}
                alt={audience.photo.alt}
                width={1200}
                height={800}
                class="h-full w-full object-cover object-center"
                loading="lazy"
                decoding="async"
              />
            </div>
            <!-- Móvil: contenido flotante solapando el borde inferior de la imagen -->
            <div class="relative z-[1] -mt-9 px-4 pb-8 pt-0 sm:-mt-10 md:mt-0 md:flex md:min-h-[26rem] md:items-center md:px-8 md:pb-10 md:pt-10 lg:min-h-[28rem] lg:px-10">
              <div class="w-full rounded-[1.25rem] border-b-[6px] border-l-[6px] border-[#b94808] bg-accent-orange p-6 text-white shadow-[6px_10px_0_0_rgba(160,55,12,0.38)] sm:p-8 md:max-w-[min(42%,26rem)] md:p-9">
                <h2
                  id="audience-title"
                  class="mb-5 text-xl font-bold leading-snug sm:text-2xl md:text-[1.35rem] md:leading-tight lg:text-[1.45rem]"
                >
                  {audience.highlight}
                </h2>
                <ul class="list-outside list-disc space-y-3 pl-4 text-sm leading-relaxed marker:text-white sm:text-base sm:leading-relaxed md:space-y-3.5">
                  {audience.roles.map((r) => (
                    <li class="pl-1">{r}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    ) : (
      <div class="bg-surface-cream">
        <div class="container">
          <div class="grid items-stretch gap-8 lg:grid-cols-2 lg:gap-14">
            <div class="order-2 flex flex-col justify-center rounded-2xl border-b-[6px] border-l-[6px] border-[#b94808] bg-accent-orange p-8 text-white shadow-[6px_10px_0_0_rgba(160,55,12,0.38)] sm:p-10 lg:order-1">
              <h2
                id="audience-title"
                class="mb-4 text-2xl font-bold leading-snug sm:text-3xl"
              >
                {audience.highlight}
              </h2>
              <ul class="list-outside list-disc space-y-3 pl-4 text-base leading-relaxed marker:text-white sm:text-lg">
                {audience.roles.map((r) => (
                  <li class="pl-1">{r}</li>
                ))}
              </ul>
            </div>
            <div class="order-1 lg:order-2">
              <img
                src={audience.photo.src}
                alt={audience.photo.alt}
                width={1000}
                height={750}
                class="h-full min-h-[220px] w-full rounded-2xl object-cover shadow-card sm:min-h-[280px] lg:min-h-[360px]"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    )
  }
</section>
