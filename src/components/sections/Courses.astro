---
import CourseTabs from "../inicio/CourseTabs";
---

<section id="cursos" class="scroll-mt-28 bg-primary py-14 text-white md:py-20" aria-labelledby="courses-title">
  <div class="container">
    <h2 id="courses-title" class="mb-3 text-left text-2xl font-bold sm:mb-4 sm:text-3xl md:text-4xl">
      Cursos de capacitación
    </h2>
    <p class="mb-10 max-w-2xl text-left text-sm leading-relaxed text-white/90 sm:mb-12 sm:text-base">
      Ocho módulos para fortalecer tu práctica con enfoque Montessori y evidencia actual.
    </p>
    <CourseTabs variant="sidebar" client:load />
  </div>
</section>
