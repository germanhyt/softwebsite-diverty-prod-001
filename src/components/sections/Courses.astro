---
import CourseTabs from "../react/CourseTabs";
import { courses } from "../../data/estrategia";
---

<section id="cursos" class="scroll-mt-28 bg-primary py-16 text-white md:py-24" aria-labelledby="courses-title">
  <div class="container">
    <h2 id="courses-title" class="mb-10 text-center text-3xl sm:mb-12 sm:text-4xl">
      Cursos de capacitación
    </h2>
    <CourseTabs courses={courses} client:visible />
  </div>
</section>
