---
import { siteConfig } from "../config/site.config";

export type NavActive = "inicio" | "estrategia" | "nosotros";

interface Props {
  active: NavActive;
  /** Texto del botón principal del nav (prototipo home: agenda; nosotros: Contáctanos). */
  ctaLabel?: string;
}

const { active, ctaLabel = "Agenda una sesión →" } = Astro.props;

const links: { href: string; label: string; id: NavActive }[] = [
  { href: "/", label: "Inicio", id: "inicio" },
  { href: "/estrategia", label: "Estrategia", id: "estrategia" },
  { href: "/nosotros", label: "Quiénes somos", id: "nosotros" },
];
---

<header class="pointer-events-none fixed top-0 z-50 w-full px-3 pt-4 sm:px-4 md:pt-6">
  <nav
    class="pointer-events-auto mx-auto flex max-w-6xl flex-col gap-3 rounded-2xl bg-surface-card px-4 py-3 shadow-nav sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:px-6 md:px-8"
      aria-label="Principal"
    >
    <div class="flex w-full items-center justify-between gap-3 sm:w-auto sm:justify-start">
      <a href="/" class="shrink-0 text-xl font-extrabold tracking-tight text-primary md:text-2xl">
        {siteConfig.name}
      </a>
      <a
        href="/#contacto"
        class="rounded-full bg-primary px-4 py-2 text-sm font-bold text-white shadow-sm transition hover:bg-primary-dark sm:hidden"
      >
        {ctaLabel.replace(/\s*→\s*$/, "")}
      </a>
    </div>

    <ul class="flex flex-wrap items-center justify-center gap-x-2 gap-y-2 text-xs font-extrabold text-primary xs:text-sm md:flex-nowrap md:gap-2 md:text-base lg:gap-3">
      {
        links.map(({ href, label, id }) => {
          const isActive = active === id;
          return (
            <li>
              <a
                href={href}
                aria-current={isActive ? "page" : undefined}
                class:list={[
                  "inline-block rounded-full px-3 py-1 transition",
                  isActive ? "bg-primary text-white shadow-sm" : "hover:text-accent-orange md:px-2",
                ]}
              >
                {label}
              </a>
            </li>
          );
        })
      }
    </ul>

    <a
      href="/#contacto"
      class="hidden whitespace-nowrap rounded-full bg-primary px-5 py-2 text-sm font-bold text-white shadow-sm transition hover:bg-primary-dark sm:inline-flex sm:text-base"
    >
      {ctaLabel}
    </a>
  </nav>
</header>

<div class="h-20 shrink-0 md:h-24" aria-hidden="true"></div>
